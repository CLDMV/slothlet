{
	"name": "@cldmv/slothlet",
	"version": "2.11.0",
	"moduleVersions": {
		"lazy": "1.3.1",
		"eager": "1.3.1",
		"async": "1.1.0",
		"live": "1.1.0"
	},
	"description": "Slothlet: Modular API Loader for Node.js. Lazy mode dynamically loads API modules and submodules only when accessed, supporting both lazy and eager loading.",
	"main": "./index.cjs",
	"module": "./index.mjs",
	"exports": {
		".": {
			"types": "./types/index.d.mts",
			"import": "./index.mjs",
			"require": "./index.cjs"
		},
		"./devcheck": {
			"types": "./types/devcheck.d.mts",
			"import": "./devcheck.mjs"
		},
		"./slothlet": {
			"slothlet-dev": {
				"types": "./types/src/slothlet.d.mts",
				"import": "./src/slothlet.mjs"
			},
			"types": "./types/dist/slothlet.d.mts",
			"import": "./dist/slothlet.mjs"
		},
		"./runtime": {
			"slothlet-dev": {
				"types": "./types/src/lib/runtime/runtime.d.mts",
				"import": "./src/lib/runtime/runtime.mjs"
			},
			"types": "./types/dist/lib/runtime/runtime.d.mts",
			"import": "./dist/lib/runtime/runtime.mjs"
		},
		"./runtime/async": {
			"slothlet-dev": {
				"types": "./types/src/lib/runtime/runtime-asynclocalstorage.d.mts",
				"import": "./src/lib/runtime/runtime-asynclocalstorage.mjs"
			},
			"types": "./types/dist/lib/runtime/runtime-asynclocalstorage.d.mts",
			"import": "./dist/lib/runtime/runtime-asynclocalstorage.mjs"
		},
		"./runtime/live": {
			"slothlet-dev": {
				"types": "./types/src/lib/runtime/runtime-livebindings.d.mts",
				"import": "./src/lib/runtime/runtime-livebindings.mjs"
			},
			"types": "./types/dist/lib/runtime/runtime-livebindings.d.mts",
			"import": "./dist/lib/runtime/runtime-livebindings.mjs"
		},
		"./helpers/*": {
			"slothlet-dev": {
				"types": "./types/src/lib/helpers/*.d.mts",
				"import": "./src/lib/helpers/*.mjs"
			},
			"types": "./types/dist/lib/helpers/*.d.mts",
			"import": "./dist/lib/helpers/*.mjs"
		},
		"./modes/*": {
			"slothlet-dev": {
				"types": "./types/src/lib/modes/*.d.mts",
				"import": "./src/lib/modes/*.mjs"
			},
			"types": "./types/dist/lib/modes/*.d.mts",
			"import": "./dist/lib/modes/*.mjs"
		},
		"./builders/*": {
			"slothlet-dev": {
				"types": "./types/src/lib/builders/*.d.mts",
				"import": "./src/lib/builders/*.mjs"
			},
			"types": "./types/dist/lib/builders/*.d.mts",
			"import": "./dist/lib/builders/*.mjs"
		},
		"./handlers/*": {
			"slothlet-dev": {
				"types": "./types/src/lib/handlers/*.d.mts",
				"import": "./src/lib/handlers/*.mjs"
			},
			"types": "./types/dist/lib/handlers/*.d.mts",
			"import": "./dist/lib/handlers/*.mjs"
		},
		"./processors/*": {
			"slothlet-dev": {
				"types": "./types/src/lib/processors/*.d.mts",
				"import": "./src/lib/processors/*.mjs"
			},
			"types": "./types/dist/lib/processors/*.d.mts",
			"import": "./dist/lib/processors/*.mjs"
		},
		"./factories/*": {
			"slothlet-dev": {
				"types": "./types/src/lib/factories/*.d.mts",
				"import": "./src/lib/factories/*.mjs"
			},
			"types": "./types/dist/lib/factories/*.d.mts",
			"import": "./dist/lib/factories/*.mjs"
		},
		"./errors": {
			"slothlet-dev": {
				"types": "./types/src/lib/errors.d.mts",
				"import": "./src/lib/errors.mjs"
			},
			"types": "./types/dist/lib/errors.d.mts",
			"import": "./dist/lib/errors.mjs"
		},
		"./i18n": {
			"slothlet-dev": {
				"types": "./types/src/lib/i18n/translations.d.mts",
				"import": "./src/lib/i18n/translations.mjs"
			},
			"types": "./types/dist/lib/i18n/translations.d.mts",
			"import": "./dist/lib/i18n/translations.mjs"
		}
	},
	"types": "./types/index.d.mts",
	"scripts": {
		"precommit": "node tools/precommit-validation.mjs",
		"debug": "node tests/debug-slothlet.mjs",
		"i18n:check": "node tools/check-i18n-languages.mjs",
		"vitest": "node tests/vitests/run-all-vitest.mjs --workers 8",
		"baseline": "npm run vitest -- --baseline",
		"coverage": "npm run vitest -- --coverage-quiet",
		"test": "npm run test:pre-build",
		"test:pre-build": "node tests/test-conditional.mjs",
		"test:post-build": "npm run test:types",
		"test:complete": "node tests/test-conditional.mjs && npm run test:post-build",
		"test:node": "node tests/run-all-tests.mjs",
		"test:all": "node tests/test-conditional.mjs && npm run test:node",
		"test:types": "node tests/validate-typescript.mjs",
		"test:performance": "node tests/performance/performance-benchmark-aggregated.mjs",
		"test:performance-simple": "node tests/performance/performance-benchmark.mjs",
		"lint": "eslint --config .configs/eslint.config.mjs .",
		"inspect": "node tools/inspect-api-structure.mjs",
		"analyze": "node tools/analyze-errors.mjs",
		"fix:headers": "node tools/fix-headers.mjs",
		"build": "npm run build:dev",
		"build:ci": "npm run build:cleanup && npm run build:dist && npm run build:types && npm run build:exports && npm run test:types && npm run build:prepend-license && npm run ci:cleanup-src",
		"build:dev": "npm run build:cleanup && npm run build:dist && npm run build:types && npm run build:exports && npm run test:types && npm run build:prepend-license && npm run build:cleanup",
		"build:unsafe": "npm run build:cleanup && npm run build:dist && npm run build:types && npm run build:exports && npm run test:types && npm run build:prepend-license",
		"ci:cleanup-src": "node tools/ci-cleanup-src.mjs",
		"build:cleanup": "shx rm -rf types && shx rm -rf dist",
		"build:dist": "shx mkdir -p dist && shx cp -r src/* dist/ && shx rm -rf dist/**/*.backup",
		"build:types": "npx tsc -p .configs/tsconfig.dts.jsonc",
		"build:exports": "node tools/build-exports.mjs",
		"build:prepend-license": "node tools/prepend-license.mjs dist",
		"prepublish-check": "npm run build && npm pack && node tools/prepublish-check.mjs",
		"docs:build": "npm run docs:build:slothlet && npm run docs:build:api-tests",
		"docs:build:slothlet": "jsdoc2md -g grouped -m dl --no-cache --separators -c \".configs/jsdoc.config.json\" --helper \"docs/generated/helpers.cjs\" --template \"docs/generated/template.hbs\" \"src/{slothlet.mjs,lib/**/**/*.mjs}\" > docs/generated/API.md",
		"docs:build:api-tests": "npm run docs:build:api-test && npm run docs:build:api-test-cjs && npm run docs:build:api-test-mixed",
		"docs:build:api-test": "shx mkdir -p docs/generated/api_tests && jsdoc2md -g grouped -m dl --no-cache --separators -c \".configs/jsdoc.config.json\" --helper \"docs/generated/helpers.cjs\" --template \"docs/generated/template.hbs\" \"api_tests/api_test/**/*.mjs\" > docs/generated/api_tests/api_test.md",
		"docs:build:api-test-cjs": "shx mkdir -p docs/generated/api_tests && jsdoc2md -g grouped -m dl --no-cache --separators -c \".configs/jsdoc.config.json\" --helper \"docs/generated/helpers.cjs\" --template \"docs/generated/template.hbs\" \"api_tests/api_test_cjs/**/*.{mjs,cjs}\" > docs/generated/api_tests/api_test_cjs.md",
		"docs:build:api-test-mixed": "shx mkdir -p docs/generated/api_tests && jsdoc2md -g grouped -m dl --no-cache --separators -c \".configs/jsdoc.config.json\" --helper \"docs/generated/helpers.cjs\" --template \"docs/generated/template.hbs\" \"api_tests/api_test_mixed/**/*.{mjs,cjs}\" > docs/generated/api_tests/api_test_mixed.md",
		"docs:build:tools": "shx mkdir -p docs/tools && jsdoc2md -g grouped -m dl --no-cache --separators -c \".configs/jsdoc.config.json\" --helper \"docs/generated/helpers.cjs\" --template \"docs/generated/template.hbs\" \"tools/**/*.mjs\" > docs/tools/build-tools.md",
		"publish:manual": "npm publish --access public"
	},
	"keywords": [
		"api",
		"api-loader",
		"api-management",
		"module-loader",
		"lazy-loading",
		"eager-loading",
		"copy-left-materialization",
		"proxy",
		"asynclocalstorage",
		"live-binding",
		"context-isolation",
		"dual-loading",
		"modular",
		"performance",
		"optimization",
		"startup-performance",
		"nodejs",
		"esm",
		"cjs",
		"mixed-modules",
		"dynamic-import",
		"deferred-loading",
		"framework",
		"typescript",
		"zero-dependencies"
	],
	"engines": {
		"node": ">=16.20.2"
	},
	"author": {
		"name": "Shinrai",
		"company": "CLDMV",
		"email": "git+npm@cldmv.net",
		"url": "https://cldmv.net"
	},
	"contributors": [
		{
			"name": "CLDMV",
			"url": "https://github.com/CLDMV"
		}
	],
	"license": "Apache-2.0",
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/shinrai"
	},
	"type": "module",
	"peerDependencies": {
		"esbuild": "^0.27.3",
		"typescript": "^5.9.3"
	},
	"peerDependenciesMeta": {
		"esbuild": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	},
	"devDependencies": {
		"@cldmv/fix-headers": "^1.2.0",
		"@cldmv/vitest-runner": "^1.0.3",
		"@eslint/css": "^0.10.0",
		"@eslint/js": "^9.33.0",
		"@eslint/json": "^0.13.1",
		"@eslint/markdown": "^7.2.0",
		"@html-eslint/parser": "^0.45.0",
		"@types/node": "^24.9.1",
		"@vitest/coverage-v8": "^4.0.18",
		"chalk": "^5.6.0",
		"chokidar": "^5.0.0",
		"dmd": "^7.1.1",
		"esbuild": "^0.27.3",
		"eslint": "^10.0.2",
		"globals": "^17.4.0",
		"jsdoc": "^4.0.4",
		"jsdoc-to-markdown": "^9.1.2",
		"jsdoc2md": "^1.0.0",
		"jsonc-parser": "^3.3.1",
		"prettier": "^3.3.3",
		"shx": "^0.4.0",
		"typescript": "^5.9.3",
		"vest": "^5.4.6",
		"vitest": "^4.0.18"
	},
	"overrides": {
		"minimatch": "^10.2.3",
		"rollup": "^4.59.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/CLDMV/slothlet.git"
	},
	"bugs": {
		"url": "https://github.com/CLDMV/slothlet/issues"
	},
	"homepage": "https://github.com/CLDMV/slothlet#readme",
	"publishConfig": {
		"access": "public"
	},
	"prepack": "npm run build:ci",
	"files": [
		"index.mjs",
		"index.cjs",
		"README.md",
		"LICENSE",
		"docs/API-RULES.md",
		"docs/API-RULES-CONDITIONS.md",
		"AGENT-USAGE.md",
		"types/dist/",
		"types/index.d.mts",
		"types/index.d.mts.map",
		"dist/"
	],
	"sideEffects": false
}
